<let/shown = true>
<if=shown>
  <div style="padding:.8rem 1rem;border-radius:8px;background:#fff0f5;border:1px solid #f3c2d6;color:#8a1f4b;display:flex;justify-content:space-between;gap:1rem;align-items:center;font-family:system-ui,sans-serif">
    <span><strong>Heads up</strong> — rendered by the remote app, embedded in the host.</span>
    <button style="border:0;background:none;cursor:pointer;font-size:1.2em;color:inherit;line-height:1" onClick() { shown = false }>×</button>
  </div>
</if>
