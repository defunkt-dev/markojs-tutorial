<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8"/>
    <title>Pricing</title>
  </head>
  <body>
    <h1>Pricing</h1>
    <div class="plan">
      <h3>Hobby</h3>
      <p class="price">$9/mo</p>
      <p>For side projects.</p>
    </div>
    <div class="plan">
      <h3>Pro</h3>
      <p class="price">$29/mo</p>
      <p>For serious builders</p>
    </div>
    <div class="plan">
      <h3>Team</h3>
      <p class="price">$99/mo</p>
      <p>For whole companies.</p>
    </div>
    <style>
      .plan { border: 1px solid #ccc; border-radius: 8px; padding: 12px; max-width: 220px; margin-bottom: 8px; }
      .price { font-weight: bold; color: #0f766e; }
    </style>
  </body>
</html>
