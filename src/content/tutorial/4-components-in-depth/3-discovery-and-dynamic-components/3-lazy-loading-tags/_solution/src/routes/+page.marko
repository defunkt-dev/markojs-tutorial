import Comments from "<comments>" with { load: "visible.comments" }

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8"/>
    <title>Article</title>
  </head>
  <body>
    <h1>The Long Read</h1>
    <for|n| from=1 to=12>
      <p>Paragraph ${n}: imagine several hundred thoughtful words here, scrolling ever onward.</p>
    </for>
    <section class="comments">
      <Comments/>
    </section>
  </body>
</html>
