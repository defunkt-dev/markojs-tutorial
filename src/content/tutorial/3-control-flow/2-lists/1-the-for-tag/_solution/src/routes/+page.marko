static const books = [
  { title: "Don Quixote", author: "Cervantes" },
  { title: "Dune", author: "Herbert" },
  { title: "Beloved", author: "Morrison" },
  { title: "The Dispossessed", author: "Le Guin" },
];

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8"/>
    <title>Reading List</title>
  </head>
  <body>
    <h1>Reading List</h1>
    <ul>
      <for|book, i| of=books>
        <li>${i + 1}. ${book.title} — ${book.author}</li>
      </for>
    </ul>
  </body>
</html>
