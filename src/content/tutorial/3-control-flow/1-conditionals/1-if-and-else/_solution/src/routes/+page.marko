<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8"/>
    <title>Quiz Result</title>
  </head>
  <body>
    <let/score=85>
    <h1>Your score: ${score}</h1>
    <if=(score >= 80)>
      <p>Excellent — you passed with style!</p>
    </if>
    <else if=(score >= 50)>
      <p>Not bad — review and retry.</p>
    </else>
    <else>
      <p>Let's go through it again together.</p>
    </else>
  </body>
</html>
