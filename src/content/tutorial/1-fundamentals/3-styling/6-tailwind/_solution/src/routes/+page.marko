import "./tailwind.css";

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8"/>
    <title>Tailwind Counter</title>
  </head>
  <body class="p-8 font-sans">
    <h1 class="text-3xl font-bold text-teal-700">Hello Marko 6</h1>
    <let/count=0>
    <button class=["mt-4 rounded px-4 py-2 text-white", count > 4 ? "bg-rose-600" : "bg-teal-600"] onClick() { count++ }>
      Count: ${count}
    </button>
  </body>
</html>
