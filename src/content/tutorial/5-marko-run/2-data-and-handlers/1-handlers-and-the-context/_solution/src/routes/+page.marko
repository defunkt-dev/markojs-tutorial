<let/result="">

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8"/>
    <title>Status</title>
  </head>
  <body>
    <h1>Service Status</h1>
    <button onClick() {
      fetch("/status")
        .then((r) => r.ok ? r.text() : `HTTP ${r.status}`)
        .then((t) => { result = t });
    }>Check</button>
    <pre>${result}</pre>
  </body>
</html>
