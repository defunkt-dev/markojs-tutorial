<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8"/>
    <title>Colour Picker</title>
  </head>
  <body>
    <h1>Colour Picker</h1>
    <div style="width:150px;height:150px;background:rgb(128, 128, 128);border-radius:12px"></div>
    <label>R <input type="range" min="0" max="255" value="128"></label>
    <label>G <input type="range" min="0" max="255" value="128"></label>
    <label>B <input type="range" min="0" max="255" value="128"></label>
    <p>rgb(128, 128, 128)</p>
  </body>
</html>
