<li style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid #eee">
  <input type="checkbox" checked=input.todo.done onChange() { input.onToggle() }>
  <span style=`flex:1;${input.todo.done ? "text-decoration:line-through;color:#94a3b8" : ""}`>${input.todo.text}</span>
  <button onClick() { input.onDelete() }>Delete</button>
</li>
