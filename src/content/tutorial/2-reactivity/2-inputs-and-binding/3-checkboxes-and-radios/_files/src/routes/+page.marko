<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8"/>
    <title>Pizza Order</title>
  </head>
  <body>
    <let/giftWrap=false>
    <let/size="medium">
    <let/toppings=["cheese"]>
    <h1>Pizza Order</h1>
    <label>
      <input type="checkbox" checked=giftWrap onChange(e) { giftWrap = e.target.checked }>
      Gift wrap
    </label>
    <fieldset>
      <legend>Size</legend>
      <label><input type="radio" value="small" onChange() { size = "small" }> Small</label>
      <label><input type="radio" value="medium" onChange() { size = "medium" }> Medium</label>
      <label><input type="radio" value="large" onChange() { size = "large" }> Large</label>
    </fieldset>
    <fieldset>
      <legend>Toppings</legend>
      <label><input type="checkbox" value="cheese"> Cheese</label>
      <label><input type="checkbox" value="olives"> Olives</label>
    </fieldset>
    <p>Order: ${size} pizza, toppings: ${toppings.join(", ") || "none"}${giftWrap ? ", gift wrapped" : ""}</p>
  </body>
</html>
