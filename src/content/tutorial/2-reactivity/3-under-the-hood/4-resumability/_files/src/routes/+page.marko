<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8"/>
    <title>Resumability</title>
  </head>
  <body>
    <let/count=0>
    <h1>Resumability</h1>
    <button onClick() { count++ }>Clicked ${count} times</button>
    <p>
      ${(() => {
        console.log("[server render] this code ran once — on the server");
        return "This paragraph was rendered on the server.";
      })()}
    </p>
  </body>
</html>
