<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8"/>
    <title>Color Mixer</title>
  </head>
  <body>
    <let/red=100>
    <let/green=100>
    <let/blue=100>
    <h1>Color Mixer</h1>
    <div style=`width:120px;height:120px;background:rgb(${red},${green},${blue})`></div>
    <button>More red</button>
    <button>More green</button>
    <button>More blue</button>
    <p>rgb(${red}, ${green}, ${blue}) — press "r" to zero out red</p>
  </body>
</html>
