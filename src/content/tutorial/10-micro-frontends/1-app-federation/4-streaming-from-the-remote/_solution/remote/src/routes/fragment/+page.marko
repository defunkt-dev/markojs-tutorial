<try>
  <div style="padding:1rem 1.25rem;border-radius:8px;background:#fff0f5;border:1px solid #f3c2d6;color:#8a1f4b;font-family:system-ui,sans-serif">
    <strong>Latest deal</strong>
    <await|deal|=new Promise((resolve) => setTimeout(() => resolve("50% off — ends tonight"), 800))>
      <p>${deal}</p>
    </await>
  </div>
  <@placeholder>
    <div style="padding:1rem 1.25rem;color:#8a1f4b;font-family:system-ui,sans-serif">Loading the latest deal…</div>
  </@placeholder>
</try>
